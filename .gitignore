# 允許 frontend 的環境配置文件（不含敏感信息）
!frontend/.env.development
!frontend/.env.production
!frontend/.env.tailscale

# admin-frontend 的 .env.production 含 Sentry DSN，由 CI secrets 注入，不入 git
admin-frontend/.env.production
# Vite 慣例：*.local 為本機覆寫，永遠不入 git
frontend/.env.*.local
admin-frontend/.env.*.local

