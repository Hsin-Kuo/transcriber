{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    // 寬鬆漸進策略：
    // - allowJs：.js 與 .ts 並存
    // - checkJs：false → .js 不參與型別檢查（避免一上線就被 noise 淹）
    // - strict：false → 新 .ts 也允許 implicit any（用 JSDoc 慢慢補）
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
