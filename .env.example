# ===== MongoDB 配置 =====
# MongoDB 連接字串
# ⚠️ Transaction 需求：MongoDB 必須跑 replica set，連線字串需含參數
# - 本地 docker-compose（single-node RS, port 27020）：
#     mongodb://localhost:27020/?replicaSet=rs0&directConnection=true
# - Atlas（已內建 replica set）：mongodb+srv://... 即可
MONGODB_URL="mongodb://localhost:27020/?replicaSet=rs0&directConnection=true"
# 資料庫名稱
MONGODB_DB_NAME="whisper_transcriber"
# MongoDB Root 密碼（Docker 部署時使用）
MONGODB_ROOT_PASSWORD="change_me_to_strong_password"

# ===== JWT 配置 =====
# ⚠️ 必要設定：JWT Secret Key（必須是高熵密鑰，建議 openssl rand -hex 32 輸出）
# 生成方式: openssl rand -hex 32
# 注意：啟動時會驗證格式與 entropy，弱密鑰（如重複字元、短字串）會拒絕啟動
JWT_SECRET_KEY="在此貼上 openssl rand -hex 32 的輸出"
# JWT 演算法
JWT_ALGORITHM="HS256"
# Access Token 過期時間（分鐘）
ACCESS_TOKEN_EXPIRE_MINUTES="15"
# Refresh Token 過期時間（天）
REFRESH_TOKEN_EXPIRE_DAYS="30"

# ===== CORS 配置 =====
# 允許的來源（逗號分隔，生產環境請設定為實際域名）
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ===== Google API Keys =====
# 支援多個 API Keys，系統會自動輪詢使用
# 如果某個 Key 失敗，會自動切換到下一個 Key

# 方式 1：使用多個編號的 Keys（推薦）
GOOGLE_API_KEY_1="your_google_api_key_1_here"
GOOGLE_API_KEY_2="your_google_api_key_2_here"
GOOGLE_API_KEY_3="your_google_api_key_3_here"
# ... 可以繼續添加更多 Keys (GOOGLE_API_KEY_4, GOOGLE_API_KEY_5, ...)

# 方式 2：使用單一 Key（向後兼容）
# GOOGLE_API_KEY="your_google_api_key_here"

# ===== OpenAI API Key =====
# 可選，用於標點符號處理
OPENAI_API_KEY="your_openai_api_key_here"

# ===== Hugging Face Token =====
# 用於 Speaker Diarization 功能
HF_TOKEN="your_huggingface_token_here"

# ===== 轉錄模型配置 =====
# faster-whisper 模型名稱。預設 large-v3-turbo：品質接近 large-v3，
# 速度與 medium 相當（809M 參數），多語（含中文）表現佳。
# 其他可選：medium（較輕）| large-v3（最準但較慢）| distil-large-v3（快，非英語較弱）
# 本地開發若想用更輕的模型，可覆寫為 medium。
WHISPER_MODEL="large-v3-turbo"
# GPU batched 推論的批次大小（每批同時餵 GPU 的 VAD 視窗數）。
# 預設 8；T4 16GB + turbo 可調到 16 換取更高吞吐。僅 GPU 路徑生效。
WHISPER_BATCH_SIZE="8"

# ===== Email 服務配置 =====
# SMTP 伺服器配置（用於發送驗證郵件）
# 如果不設定 SMTP，開發環境會在 console 輸出郵件內容
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password_here"
FROM_EMAIL="your_email@gmail.com"
FROM_NAME="Sound Lite 轉錄服務"
# 前端 URL（用於生成驗證連結）
FRONTEND_URL="http://localhost:5173"

# ===== 部署環境配置 =====
# 部署環境：local（本地開發）| aws（AWS 部署）
DEPLOY_ENV="local"
# 應用角色（僅 DEPLOY_ENV=aws 時有效）：server（Web API）| worker（AI 轉錄）
# APP_ROLE="server"

# ===== 上傳設定 =====
# 單檔上傳大小上限（MB），預設 3072（3 GB）
# ⚠️ 提高此值前請確認 Web Server 磁碟空間足夠：每個進行中的上傳會在
#    本機暫存 ≈ 1 份完整檔案，等組裝完成並上傳到 S3 後才釋放
MAX_UPLOAD_SIZE_MB="3072"

# ===== AWS 設定（僅 DEPLOY_ENV=aws 時需要）=====
# S3_BUCKET="transcriber-files"
# S3_REGION="ap-northeast-1"
# SQS_QUEUE_URL="https://sqs.ap-northeast-1.amazonaws.com/123456789012/transcriber-tasks"
# ⚠️ Worker 訊息簽名密鑰（Web Server 和 Worker 必須使用相同的值）
# 生成方式: openssl rand -hex 32
# WORKER_SECRET="在此貼上 openssl rand -hex 32 的輸出"

# ===== Email 發送方式 =====
# console（印到終端，預設）| smtp（Gmail 等 SMTP）| ses（AWS SES）| resend
# ⚠️ 啟動時依 EMAIL_PROVIDER 強制驗證對應設定：
#   - resend  需 FROM_EMAIL + RESEND_API_KEY（SSM: /transcriber/resend-api-key）
#   - ses     需 FROM_EMAIL
#   - smtp    需 SMTP_HOST + SMTP_USER + SMTP_PASSWORD + FROM_EMAIL
#   - console 不檢查
# FROM_EMAIL 對 resend / ses 必須是 provider 已驗證的 sender domain
EMAIL_PROVIDER="console"

# Resend API key（EMAIL_PROVIDER=resend 時必填，生產建議放 SSM）
# RESEND_API_KEY="re_..."

# Resend Webhook secret — 接收 bounce / complaint 事件用
# Resend dashboard → Webhooks → Add Endpoint：
#   URL: https://soundlite.app/webhooks/resend
#   Events: email.bounced, email.complained, email.suppressed
# 取得 whsec_... 後填入；生產建議 SSM: /transcriber/resend-webhook-secret
# RESEND_WEBHOOK_SECRET="whsec_..."

# ===== 藍新金流 =====
# 商店代號（藍新後台 → 商店資料）
NEWEBPAY_MERCHANT_ID="your_merchant_id"
# AES Key / IV（藍新後台 → 商店資料 → 串接金鑰）
NEWEBPAY_HASH_KEY="your_32_char_hash_key"
NEWEBPAY_HASH_IV="your_16_char_hash_iv"
# 環境：sandbox（測試）/ production（正式）
NEWEBPAY_ENV="sandbox"
# 訂閱方案定價（TWD，整數）
NEWEBPAY_PRICE_BASIC_MONTHLY="299"
NEWEBPAY_PRICE_BASIC_YEARLY="3289"
NEWEBPAY_PRICE_PRO_MONTHLY="899"
NEWEBPAY_PRICE_PRO_YEARLY="9889"
# 後端對外網址（藍新 Notify 需要可從外部存取的 URL）
# 本地開發可用 ngrok：ngrok http 8000 → 填入 https://xxxx.ngrok.io
BACKEND_URL="http://localhost:8000"

# ===== Sentry（錯誤追蹤）=====
# 留空即關閉，本地開發不會送任何資料到 Sentry
# 在 https://sentry.io 建立 Python 專案後複製 DSN 貼入
SENTRY_DSN=""
# 環境標籤（留空會自動組成 "<DEPLOY_ENV>-<component>"，例：aws-server / aws-worker）
SENTRY_ENVIRONMENT=""
# Performance tracing 取樣比例（0.0 ~ 1.0，正式環境建議 0.1）
SENTRY_TRACES_SAMPLE_RATE="0.1"
# Profiling 取樣比例（0.0 ~ 1.0，預設關閉）
SENTRY_PROFILES_SAMPLE_RATE="0.0"
# Release 版本標籤，可填 git SHA（CI 部署時自動帶入）
SENTRY_RELEASE=""
